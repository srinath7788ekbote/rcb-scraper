# ── Mode ──────────────────────────────────────────────────────────────────────
# "test-merch"   → merch product page (safe testing)
# "live-tickets" → live ticket sale page
MONITOR_MODE=live-tickets

# ── Target URL ────────────────────────────────────────────────────────────────
# Leave blank to use the default for the selected mode.
# test-merch default:  https://shop.royalchallengers.com/merchandise/152
# live-tickets default: https://shop.royalchallengers.com/
TARGET_URL=https://shop.royalchallengers.com/

# ── Polling ───────────────────────────────────────────────────────────────────
CHECK_INTERVAL=120

# ── Price filter (live-tickets mode) ──────────────────────────────────────────
MIN_PRICE=2000
MAX_PRICE=5000

# ── Ticket booking (live-tickets mode) ───────────────────────────────────────
# Number of tickets to select in the "How many tickets?" popup (1–6)
TICKET_QUANTITY=4
# Max price per ticket — stands above this are skipped
PRICE_PER_TICKET_MAX=5000
# How many stands to target in parallel (first N stands sorted cheapest first)
MAX_STAND_WORKERS=7
# Seconds between each worker's Chrome startup (reduces server hammering)
WORKER_STARTUP_JITTER=0.4

# ── Checkout details ─────────────────────────────────────────────────────────
QUANTITY=4
NAMES=Srinath Ekbote,Anjali Ekbote,Prabhu,Shruti
UPI_VPA=srinath7788ekbote1@ybl
# Merch product options (leave blank to skip/use default)
MERCH_SIZE=L
MERCH_CATEGORY=

# ── Contact (used if login/guest forms appear) ───────────────────────────────
CONTACT_EMAIL=srinath7788ekbote@gmail.com
CONTACT_PHONE=9916843394
GENDER=Male

# ── Shipping Address ─────────────────────────────────────────────────────────
ADDRESS_LINE1=Prestige Bagamane Temple bells
ADDRESS_LINE2= RR nagar
ADDRESS_LANDMARK= Gopalan arcade mall
ADDRESS_CITY= Bangalore
ADDRESS_STATE= Karnataka
ADDRESS_PINCODE= 560098

# ── Notifications & alerts ────────────────────────────────────────────────────
ENABLE_NOTIFICATIONS=1
# Gmail SMTP for auto-sending email (optional — falls back to Gmail compose draft)
# To get app password: Google Account → Security → 2-Step Verification → App passwords
SMTP_EMAIL=srinath7788ekbote@gmail.com
SMTP_PASSWORD=
# Recipient email
NOTIFY_EMAIL=ekbotesrinath@gmail.com
# WhatsApp numbers (comma-separated, with country code, no + prefix)
NOTIFY_WHATSAPP=919916843394,919741446565

# ── Misc ──────────────────────────────────────────────────────────────────────
MAX_RETRIES=5
SCREENSHOT_DIR=screenshots
LOG_FILE=monitor.log
# Seconds to wait for manual seat selection if auto-select fails on venue map
MANUAL_SEAT_TIMEOUT=60
# Seconds to wait for user to enter OTP during login
OTP_TIMEOUT=90
# Chrome profile dir for session persistence (login survives restarts)
# Delete this folder to force a fresh login
CHROME_PROFILE_DIR=chrome_profile
